FROM alpine:3.20

RUN apk add --no-cache libstdc++ ca-certificates openssl

RUN addgroup -S p2p && adduser -S p2p -G p2p

COPY --chown=p2p:p2p build/go_coordinator /usr/local/bin/
COPY --chown=p2p:p2p build/cpp_daemon /usr/local/bin/
COPY --chown=p2p:p2p target/bundle/P2PVersionControl /opt/p2p-ui/

USER p2p
EXPOSE 8080 9876

ENTRYPOINT ["/usr/local/bin/go_coordinator"]
